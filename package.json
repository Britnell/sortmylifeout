{
  "name": "sortmylife",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --check .",
    "migration": "wrangler d1 execute sortinglifedb --file=src/db/schema.sql --remote",
    "check": "prettier --write . && eslint --fix",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-router": "1.166.8",
    "@tanstack/react-router-devtools": "1.166.9",
    "@tanstack/react-router-ssr-query": "1.166.9",
    "@tanstack/react-start": "1.166.14",
    "@tanstack/router-plugin": "1.166.12",
    "better-auth": "^1.6.9",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "overrides": {
    "@tanstack/router-core": "1.166.7"
  },
  "resolutions": {
    "@tanstack/router-core": "1.166.7"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5",
    "wrangler": "^4.70.0"
  }
}
